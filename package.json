{
  "name": "quote-bot",
  "version": "2.0.0",
  "description": "Telegram quote bot — grammY + TypeScript rewrite",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp -R src/i18n/locales dist/i18n/locales",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "tdlib:types": "tdl-install-types prebuilt-tdlib && mv tdlib-types.d.ts src/types/tdlib-types.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LyoSU/quote-bot.git"
  },
  "author": "LyoSU",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LyoSU/quote-bot/issues"
  },
  "homepage": "https://github.com/LyoSU/quote-bot#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "dotenv": "^16.4.7",
    "grammy": "^1.43.0",
    "mongoose": "^8.9.3",
    "pino": "^10.3.1",
    "prebuilt-tdlib": "^0.1008062.2",
    "prom-client": "^15.1.3",
    "sharp": "^0.33.5",
    "tdl": "^8.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  }
}
