# Validated by src/config/env.ts on startup; the process exits if any are bad.

# ─── Required ────────────────────────────────────────────────────────────────
BOT_TOKEN=""
MONGODB_URI="mongodb://mongo:27017/QuoteBot"
QUOTE_API_URI="http://api:4888"

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
# LOG_LEVEL: fatal|error|warn|info|debug|trace
LOG_LEVEL=info
# /health + Prometheus /metrics endpoint.
HEALTH_PORT=3000
# Max updates processed concurrently across chats (per-chat order preserved).
BOT_CONCURRENCY=500
# Mongo connection pool ceiling.
MONGO_MAX_POOL=50
# How often aggregated stats are flushed (ms).
STATS_FLUSH_MS=60000

# ─── TDLib (optional; disabled without credentials) ──────────────────────────
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
# Hard kill-switch regardless of credentials (1/true).
DISABLE_TDLIB=""

# ─── Mini App deep links ─────────────────────────────────────────────────────
MINI_APP_SHORT_NAME="app"
# MINI_APP_URL=""

# ─── Sticker packs ───────────────────────────────────────────────────────────
STICKER_KEEP_COUNT=10

# ─── Ads & admin (optional) ──────────────────────────────────────────────────
# gramads token — ads are shown only to ru-locale users in private chats.
GRAMADS_TOKEN=""
# Bot owner's Telegram id — gates privileged commands (/refund).
ADMIN_ID=""
